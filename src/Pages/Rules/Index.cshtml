@page
@model Matddns.Pages.Rules.IndexModel
@{
    ViewData["Title"] = "Rules – Matddns";
}

<div class="page-header">
    <div>
        <h1>Rules</h1>
        <p>Each rule writes a record from an ordered failover source list. First reachable source wins.</p>
    </div>
    <a class="button" href="/Rules/Edit">+ New rule</a>
</div>

@if (!string.IsNullOrEmpty(Model.Notice)) { <div class="alert ok">@Model.Notice</div> }
@if (!string.IsNullOrEmpty(Model.Error)) { <div class="alert err">@Model.Error</div> }

@if (Model.Rules.Count == 0)
{
    <div class="empty-state">
        No rules yet.<br />
        <a class="button" style="margin-top:12px;" href="/Rules/Edit">Create the first rule</a>
    </div>
}

@foreach (var r in Model.Rules)
{
    var dg = Model.AllDomains.FirstOrDefault(d => d.Id == r.DomainGroupId);
    var de = dg?.Entries.FirstOrDefault(e => e.Id == r.DomainEntryId);
    var sources = r.SourceEntryIdsInOrder.Select(Model.SourceLabel).ToList();
    var statusCls = string.IsNullOrEmpty(r.LastResult) ? "muted"
        : r.LastResult.StartsWith("ok", StringComparison.OrdinalIgnoreCase) ? "ok"
        : r.LastResult.StartsWith("err", StringComparison.OrdinalIgnoreCase) ? "err" : "warn";
    var valLabel = r.Validation switch
    {
        RuleValidation.Ping => "✓ Ping",
        RuleValidation.TcpPort => $"✓ TCP:{r.ValidationPort}",
        _ => null
    };

    <a class="list-item" href="/Rules/Edit?id=@r.Id">
        <div class="li-main">
            <span class="li-title mono">@(de != null ? de.Display : "(domain missing)")</span>
            <span class="li-sub">
                @(dg?.Name ?? "—") · @(sources.Count > 0 ? string.Join(" → ", sources) : "no sources")
            </span>
            <span class="li-sub">
                @if (!string.IsNullOrEmpty(r.LastValue) && r.LastChange != null)
                {
                    <text>last set: <span class="mono">@r.LastValue</span> · @Tz.Format(r.LastChange, "yyyy-MM-dd HH:mm")</text>
                }
                else
                {
                    <text>not set yet</text>
                }
            </span>
        </div>
        <div class="li-side">
            @if (valLabel != null) { <span class="badge info">@valLabel</span> }
            <span class="status-pill"><span class="status-dot @statusCls"></span>@(r.Trigger == RuleTrigger.OnChange ? "on IP change" : $"every {r.IntervalSeconds}s")</span>
            @if (!r.Enabled) { <span class="badge muted">disabled</span> }
            <span class="muted">›</span>
        </div>
    </a>
}
