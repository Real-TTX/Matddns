@page
@model Matddns.Pages.Rules.IndexModel
@{
    ViewData["Title"] = "Rules – Matddns";
}

<div class="page-header">
    <div><h1>Rules</h1></div>
    <a class="button" href="/Rules/Edit">+ New rule</a>
</div>

@if (!string.IsNullOrEmpty(Model.Notice)) { <div class="alert ok">@Model.Notice</div> }
@if (!string.IsNullOrEmpty(Model.Error)) { <div class="alert err">@Model.Error</div> }

@if (Model.Rules.Count == 0)
{
    <div class="empty-state">
        No rules yet.<br />
        <a class="button" style="margin-top:12px;" href="/Rules/Edit">Create the first rule</a>
    </div>
}
else
{
    <div data-dt>
        <div class="table-toolbar">
            <div class="dt-search">
                <span class="ico">⌕</span>
                <input type="text" data-dt-search placeholder="Search rules…" autocomplete="off" />
            </div>
            <select data-dt-filter="status" aria-label="Filter by status">
                <option value="">All states</option>
                <option value="ok">OK</option>
                <option value="issue">Issues</option>
                <option value="disabled">Disabled</option>
            </select>
            <span class="dt-count" data-dt-count></span>
        </div>
        <div class="dtable-wrap">
            <table class="dtable">
                <thead>
                    <tr><th>Record</th><th>Group</th><th>Failover</th><th>Last set</th><th>Status</th><th></th></tr>
                </thead>
                @foreach (var r in Model.Rules)
                {
                    var dg = Model.AllDomains.FirstOrDefault(d => d.Id == r.DomainGroupId);
                    var de = dg?.Entries.FirstOrDefault(e => e.Id == r.DomainEntryId);
                    var sources = r.SourceEntryIdsInOrder.Select(Model.SourceLabel).ToList();
                    var statusKey = !r.Enabled ? "disabled"
                        : (!string.IsNullOrEmpty(r.LastResult) && r.LastResult.StartsWith("ok", StringComparison.OrdinalIgnoreCase)) ? "ok"
                        : (!string.IsNullOrEmpty(r.LastResult) && (r.LastResult.StartsWith("err", StringComparison.OrdinalIgnoreCase) || r.LastResult == "no source" || r.LastResult == "target missing")) ? "issue"
                        : "pending";
                    var dot = statusKey switch { "ok" => "ok", "issue" => "err", "disabled" => "muted", _ => "warn" };
                    var triggerText = (r.OnChange, r.IntervalSeconds > 0) switch
                    {
                        (true, true) => $"on change · every {r.IntervalSeconds}s",
                        (true, false) => "on change",
                        (false, true) => $"every {r.IntervalSeconds}s",
                        _ => "manual"
                    };
                    var recordText = de != null ? de.Display : "(domain missing)";
                    var search = $"{recordText} {dg?.Name} {string.Join(' ', sources)} {r.LastValue} {statusKey}";
                    <tbody class="dt-group" data-search="@search" data-status="@statusKey" data-href="/Rules/Edit?id=@r.Id">
                        <tr class="dt-parent">
                            <td class="dt-name mono">@recordText</td>
                            <td class="cell-muted">@(dg?.Name ?? "—")</td>
                            <td class="cell-muted">@(sources.Count > 0 ? string.Join(" → ", sources) : "no sources") <span class="muted-small">· @triggerText</span></td>
                            <td>
                                @if (!string.IsNullOrEmpty(r.LastValue) && r.LastChange != null)
                                {
                                    <span class="mono">@r.LastValue</span> <span class="muted-small">@Tz.Format(r.LastChange, "MM-dd HH:mm")</span>
                                }
                                else
                                {
                                    <span class="cell-muted">—</span>
                                }
                            </td>
                            <td><span class="status-pill"><span class="status-dot @dot"></span>@statusKey</span></td>
                            <td class="dt-go">›</td>
                        </tr>
                    </tbody>
                }
                <tbody class="dt-empty" hidden><tr><td colspan="6">No rules match your search.</td></tr></tbody>
            </table>
        </div>
    </div>
}
