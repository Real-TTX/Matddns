@page
@model Matddns.Pages.Sources.EditModel
@{
    var g = Model.Group;
    var isNew = Model.IsNew;
    var kind = g?.Kind ?? SourceKind.PublicIp;
    ViewData["Title"] = (isNew ? "New source" : g!.Name) + " – Matddns";
}

<a class="back-link" href="/Sources">‹ back to Sources</a>

<div class="page-header">
    <div>
        <h1>@(isNew ? "New source group" : g!.Name)</h1>
        <p>@(isNew ? "Pick a type – the matching fields appear automatically." : "Configuration and entries of this source.")</p>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Notice)) { <div class="alert ok">@Model.Notice</div> }
@if (!string.IsNullOrEmpty(Model.Error)) { <div class="alert err">@Model.Error</div> }

@if (!string.IsNullOrEmpty(Model.TestResult))
{
    <div class="test-result @(Model.TestOk ? "ok" : "err")">
        <strong>@(Model.TestOk ? "✓ Test succeeded" : "✗ Test failed")</strong>
        <span class="mono">@Model.TestResult</span>
    </div>
}

<div class="card">
    <form method="post" asp-page-handler="@(isNew ? "Create" : "Save")">
        @if (!isNew) { <input type="hidden" name="Id" value="@g!.Id" /> }

        <div class="form-grid">
            <div class="field">
                <label>Name</label>
                <input type="text" name="Name" value="@(g?.Name ?? "")" required placeholder="e.g. Home Unifi" />
            </div>

            <div class="field">
                <label>Type</label>
                @if (isNew)
                {
                    <select name="Kind" id="kindSelect">
                        <option value="PublicIp">Public IP (of the container)</option>
                        <option value="Unifi">Unifi (UDM / UGW)</option>
                        <option value="Static">Static IP (fixed value)</option>
                    </select>
                }
                else
                {
                    var typeLabel = kind switch { SourceKind.Unifi => "Unifi (UDM / UGW)", SourceKind.Static => "Static IP (fixed value)", _ => "Public IP (of the container)" };
                    <input type="text" value="@typeLabel" disabled />
                    <div class="hint">Type cannot be changed after creation.</div>
                }
            </div>

            <div class="field full">
                <label>Interval (seconds)</label>
                <input type="number" name="IntervalSeconds" value="@(g?.IntervalSeconds ?? 60)" min="15" />
            </div>
        </div>

        <!-- Unifi fields -->
        <div class="type-fields @(kind == SourceKind.Unifi ? "active" : "")" data-kind="Unifi">
            <div class="form-grid" style="margin-top:16px;">
                <div class="field">
                    <label>Base URL</label>
                    <input type="text" name="UniUrl" value="@(g?.Unifi?.BaseUrl ?? "")" placeholder="https://10.10.0.1" />
                    <div class="hint">Without a scheme, https:// is added automatically.</div>
                </div>
                <div class="field">
                    <label>Site</label>
                    <input type="text" name="UniSite" value="@(g?.Unifi?.Site ?? "default")" />
                </div>
                <div class="field">
                    <label>Username</label>
                    <input type="text" name="UniUser" value="@(g?.Unifi?.Username ?? "")" autocomplete="off" />
                    <div class="hint">Local UniFi account (no Ubiquiti cloud login), 2FA off.</div>
                </div>
                <div class="field">
                    <label>Password</label>
                    <input type="password" name="UniPass" placeholder="@(isNew ? "" : "•••••• (leave empty = unchanged)")" autocomplete="new-password" />
                </div>
                <div class="field full">
                    <div class="checkbox-field">
                        <input type="checkbox" id="UniIgnoreCert" name="UniIgnoreCert" value="true" @(g?.Unifi?.IgnoreCertificate != false ? "checked" : "") />
                        <label for="UniIgnoreCert">Ignore self-signed certificate (recommended for UDM)</label>
                    </div>
                </div>
            </div>
        </div>

        <!-- Public IP fields -->
        <div class="type-fields @(kind == SourceKind.PublicIp ? "active" : "")" data-kind="PublicIp">
            <p class="muted" style="margin-top:16px;">No further configuration needed – the container's public IP is detected automatically.</p>
        </div>

        <!-- Static fields -->
        <div class="type-fields @(kind == SourceKind.Static ? "active" : "")" data-kind="Static">
            <div class="form-grid" style="margin-top:16px;">
                <div class="field full">
                    <label>Static IP</label>
                    <input type="text" name="StaticIp" value="@(g?.Static?.Ip ?? "")" placeholder="203.0.113.10" />
                    <div class="hint">Fixed value written by rules using this source – e.g. a known server or fallback IP.</div>
                </div>
            </div>
        </div>

        <div class="actions">
            <button type="submit">@(isNew ? "Create" : "Save")</button>
            <a class="button ghost" href="/Sources">Cancel</a>
            @if (!isNew)
            {
                @if (kind != SourceKind.Static)
                {
                    <button type="submit" class="ghost" asp-page-handler="Test" name="Id" value="@g!.Id">Test connection</button>
                }
                <button type="submit" class="ghost" asp-page-handler="Refresh" name="Id" value="@g!.Id">Check now</button>
                <button type="submit" class="danger" asp-page-handler="Delete" name="Id" value="@g.Id" onclick="return confirm('Remove group and all entries?');">Delete group</button>
            }
        </div>
    </form>
</div>

@if (!isNew)
{
    <div class="section-title"><h2>Entries</h2></div>
    <div class="card">
        <table>
            <thead>
                <tr>
                    <th>Label</th>
                    <th>Interface</th>
                    <th>Current IP</th>
                    <th>Last check</th>
                    <th>Status</th>
                    @if (kind == SourceKind.Unifi) { <th></th> }
                </tr>
            </thead>
            <tbody>
            @foreach (var e in g!.Entries)
            {
                var status = e.LastError == null ? (string.IsNullOrEmpty(e.CurrentIp) ? "warn" : "ok") : "err";
                <tr>
                    <td>@e.Label</td>
                    <td class="mono">@(e.InterfaceName ?? "—")</td>
                    <td class="mono">@(e.CurrentIp ?? "—")</td>
                    <td><span class="muted-small">@(e.LastChecked?.ToString("yyyy-MM-dd HH:mm:ss") ?? "—") UTC</span></td>
                    <td><span class="status-pill"><span class="status-dot @status"></span>@(e.LastError ?? (string.IsNullOrEmpty(e.CurrentIp) ? "pending" : "ok"))</span></td>
                    @if (kind == SourceKind.Unifi)
                    {
                        <td style="text-align:right">
                            <form method="post" asp-page-handler="DeleteEntry" style="display:inline">
                                <input type="hidden" name="Id" value="@g.Id" />
                                <input type="hidden" name="EntryId" value="@e.Id" />
                                <button type="submit" class="danger" onclick="return confirm('Remove entry?');">×</button>
                            </form>
                        </td>
                    }
                </tr>
            }
            </tbody>
        </table>

        @if (kind == SourceKind.Unifi)
        {
            <form method="post" asp-page-handler="AddEntry" class="form-grid" style="margin-top:16px;">
                <input type="hidden" name="Id" value="@g.Id" />
                <div class="field">
                    <label>Label</label>
                    <input type="text" name="Label" placeholder="LTE Failover" required />
                </div>
                <div class="field">
                    <label>Interface</label>
                    <input type="text" name="InterfaceName" placeholder="wan2 / www / wan" required />
                    <div class="hint">Name from the UDM (e.g. wan, wan2, www).</div>
                </div>
                <div class="field full">
                    <button type="submit">+ Add entry</button>
                </div>
            </form>
        }
    </div>
}

@if (isNew)
{
    <script>
        (function () {
            var sel = document.getElementById('kindSelect');
            var fields = document.querySelectorAll('.type-fields');
            function sync() {
                fields.forEach(function (f) {
                    f.classList.toggle('active', f.getAttribute('data-kind') === sel.value);
                });
            }
            sel.addEventListener('change', sync);
            sync();
        })();
    </script>
}
