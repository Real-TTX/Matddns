@page
@model Matddns.Pages.Sources.EditModel
@{
    var g = Model.Group;
    var isNew = Model.IsNew;
    var kind = g?.Kind ?? SourceKind.PublicIp;
    ViewData["Title"] = (isNew ? "New source" : g!.Name) + " – Matddns";
}

<a class="back-link" href="/Sources">‹ back to Sources</a>

<div class="page-header">
    <div>
        <h1>@(isNew ? "New source group" : g!.Name)</h1>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Notice)) { <div class="alert ok">@Model.Notice</div> }
@if (!string.IsNullOrEmpty(Model.Error)) { <div class="alert err">@Model.Error</div> }

@if (!string.IsNullOrEmpty(Model.TestResult))
{
    <div class="test-result @(Model.TestOk ? "ok" : "err")">
        <strong>@(Model.TestOk ? "✓ Test succeeded" : "✗ Test failed")</strong>
        <span class="mono">@Model.TestResult</span>
    </div>
}

<div class="card">
    <form method="post" asp-page-handler="@(isNew ? "Create" : "Save")">
        @if (!isNew) { <input type="hidden" name="Id" value="@g!.Id" /> }

        <div class="form-grid">
            <div class="field">
                <label>Name</label>
                <input type="text" name="Name" value="@(g?.Name ?? "")" required placeholder="e.g. Home Unifi" />
            </div>

            <div class="field">
                <label>Type</label>
                @if (isNew)
                {
                    <select name="Kind" id="kindSelect">
                        <option value="PublicIp">Public IP</option>
                        <option value="Unifi">Unifi</option>
                        <option value="Static">Static IP</option>
                        <option value="Push">DynDNS Server</option>
                        <option value="Dns">DNS lookup</option>
                    </select>
                }
                else
                {
                    var typeLabel = kind switch { SourceKind.Unifi => "Unifi", SourceKind.Static => "Static IP", SourceKind.Push => "DynDNS Server", SourceKind.Dns => "DNS lookup", _ => "Public IP" };
                    <input type="text" value="@typeLabel" disabled />
                }
            </div>

            @if (isNew || kind != SourceKind.Push)
            {
                <div class="field full" id="intervalField">
                    <label>Interval (seconds)</label>
                    <input type="number" name="IntervalSeconds" value="@(g?.IntervalSeconds ?? 60)" min="15" />
                </div>
            }
        </div>

        <!-- Unifi fields -->
        <div class="type-fields @(kind == SourceKind.Unifi ? "active" : "")" data-kind="Unifi">
            <div class="form-grid" style="margin-top:16px;">
                <div class="field">
                    <label>Base URL</label>
                    <input type="text" name="UniUrl" value="@(g?.Unifi?.BaseUrl ?? "")" placeholder="https://10.10.0.1" />
                </div>
                <div class="field">
                    <label>Site</label>
                    <input type="text" name="UniSite" value="@(g?.Unifi?.Site ?? "default")" />
                </div>
                <div class="field">
                    <label>Username</label>
                    <input type="text" name="UniUser" value="@(g?.Unifi?.Username ?? "")" autocomplete="off" />
                </div>
                <div class="field">
                    <label>Password</label>
                    <input type="password" name="UniPass" placeholder="@(isNew ? "" : "•••••• (leave empty = unchanged)")" autocomplete="new-password" />
                </div>
                <div class="field full">
                    <div class="checkbox-field">
                        <input type="checkbox" id="UniIgnoreCert" name="UniIgnoreCert" value="true" @(g?.Unifi?.IgnoreCertificate != false ? "checked" : "") />
                        <label for="UniIgnoreCert">Ignore self-signed certificate</label>
                    </div>
                </div>
            </div>
        </div>

        <!-- Public IP fields -->
        <div class="type-fields @(kind == SourceKind.PublicIp ? "active" : "")" data-kind="PublicIp"></div>

        <!-- Static fields -->
        <div class="type-fields @(kind == SourceKind.Static ? "active" : "")" data-kind="Static">
            <div class="form-grid" style="margin-top:16px;">
                <div class="field">
                    <label>Static IPv4</label>
                    <input type="text" name="StaticIp" value="@(g?.Static?.Ip ?? "")" placeholder="203.0.113.10" />
                </div>
                <div class="field">
                    <label>Static IPv6</label>
                    <input type="text" name="StaticIpv6" value="@(g?.Static?.Ipv6 ?? "")" placeholder="2001:db8::1" />
                </div>
            </div>
        </div>

        <!-- DNS lookup fields -->
        <div class="type-fields @(kind == SourceKind.Dns ? "active" : "")" data-kind="Dns">
            <div class="form-grid" style="margin-top:16px;">
                <div class="field full">
                    <label>Hostname</label>
                    <input type="text" name="DnsHost" value="@(g?.Dns?.Hostname ?? "")" placeholder="xxxxxxxx.myfritz.net" />
                </div>
            </div>
        </div>

        <!-- Push / DynDNS receiver fields -->
        <div class="type-fields @(kind == SourceKind.Push ? "active" : "")" data-kind="Push">
            @if (!isNew)
            {
                var baseUrl = Model.BaseUrl;
                var token = g!.Push?.Token ?? "";
                var host = baseUrl.Replace("https://", "").Replace("http://", "");
                var isDyn = g.Push?.Dynamic == true;
                var baseFqdn = g.Push?.BaseFqdn ?? "";
                <div class="form-grid" style="margin-top:16px;">
                    <div class="field full">
                        <label>Update URL</label>
                        <input type="text" value="@(isDyn ? $"{baseUrl}/update?token={token}&hostname=<name>.{baseFqdn}&myip=%i" : $"{baseUrl}/api/update?token={token}&ipv4=<your-ipv4>&ipv6=<your-ipv6>")" readonly onclick="this.select()" />
                        @if (isDyn)
                        {
                            <p class="muted-small" style="margin:6px 0 0;">Dynamic receiver: the device sends <span class="mono">&amp;hostname=&lt;name&gt;.@baseFqdn</span> (its own name under the namespace) — that record is created/updated.</p>
                        }
                        <button type="button" class="ghost sm" style="margin-top:8px;" onclick="document.getElementById('pushDocs').showModal()">Documentation</button>
                    </div>
                    <div class="field full">
                        <label>Token</label>
                        <input type="text" value="@token" readonly onclick="this.select()" />
                    </div>
                </div>

                <div class="section-title" style="margin-top:18px;"><h2>Dynamic receiver</h2></div>
                <div class="form-grid">
                    <div class="field full checkbox-field">
                        <input type="checkbox" name="PushDynamic" value="true" id="pushDyn" @(g.Push?.Dynamic == true ? "checked" : "") onchange="document.getElementById('pushDynFields').style.display=this.checked?'':'none'" />
                        <label for="pushDyn">Push sets the record named in the request — one token for a whole namespace (friends / many devices)</label>
                    </div>
                </div>
                <div class="form-grid" id="pushDynFields" style="@(g.Push?.Dynamic == true ? "" : "display:none")">
                    <div class="field">
                        <label>Target zone (Netcup)</label>
                        <select name="PushTargetGroup">
                            <option value="">—</option>
                            @foreach (var d in Model.NetcupGroups)
                            {
                                <option value="@d.Id" selected="@(g.Push?.TargetDomainGroupId == d.Id)">@d.Name</option>
                            }
                        </select>
                    </div>
                    <div class="field">
                        <label>Zone</label>
                        <input type="text" name="PushZone" value="@(g.Push?.Zone ?? "")" placeholder="h5x.de" />
                    </div>
                    <div class="field full">
                        <label>Namespace prefix</label>
                        <input type="text" name="PushPrefix" value="@(g.Push?.Prefix ?? "")" placeholder="dynamic  →  &lt;name&gt;.dynamic.h5x.de" />
                    </div>
                </div>

                <dialog id="pushDocs" class="modal">
                    <div class="modal-head">
                        <strong>DynDNS Server — setup</strong>
                        <button type="button" class="modal-x" aria-label="Close" onclick="this.closest('dialog').close()">✕</button>
                    </div>
                    <div class="modal-body">
                        <p class="muted-small" style="margin-top:0;">The token is pre‑filled below. Use a host reachable from the device — not localhost.</p>

                        <details name="pushdocs" class="acc">
                            <summary>FRITZ!Box</summary>
                            <div class="acc-body">
                                <label>Update URL</label>
                                <input type="text" value="@(isDyn ? $"{baseUrl}/nic/update?token={token}&hostname=<domain>&ipv4=<ipaddr>&ipv6=<ip6addr>" : $"{baseUrl}/nic/update?token={token}&ipv4=<ipaddr>&ipv6=<ip6addr>")" readonly onclick="this.select()" />
                                @if (isDyn)
                                {
                                    <p class="muted-small" style="margin:6px 0 0;">Internet → Permit Access → DynDNS → <em>custom provider</em>. Set <strong>Domainname</strong> = <span class="mono">&lt;name&gt;.@baseFqdn</span> — FRITZ!Box sends it as <span class="mono">&lt;domain&gt;</span>; user / password can be anything.</p>
                                }
                                else
                                {
                                    <p class="muted-small" style="margin:6px 0 0;">Internet → Permit Access → DynDNS → <em>custom provider</em>. Domain / user / password can be anything; FRITZ!Box fills <span class="mono">&lt;ipaddr&gt;</span> / <span class="mono">&lt;ip6addr&gt;</span>.</p>
                                }
                            </div>
                        </details>

                        <details name="pushdocs" class="acc">
                            <summary>UniFi (UDM / UGW)</summary>
                            <div class="acc-body">
                                <p class="muted-small" style="margin:10px 0 8px;">Settings → Internet → <em>your WAN</em> → Dynamic DNS → <strong>Create New</strong></p>
                                <table class="api-table">
                                    <tbody>
                                        <tr><td>Service</td><td class="mono">custom</td></tr>
                                        <tr>
                                            <td>Hostname</td>
                                            @if (isDyn) { <td><span class="mono">&lt;name&gt;.@baseFqdn</span> — becomes the record</td> }
                                            else { <td>any FQDN, label only — e.g. <span class="mono">wan.example.com</span></td> }
                                        </tr>
                                        <tr><td>Username</td><td class="mono">matddns</td></tr>
                                        <tr><td>Password</td><td class="mono">@token</td></tr>
                                        <tr><td>Server</td><td class="mono">@(isDyn ? $"{host}/update?token=%p&hostname=%h&ipv4=%i" : $"{host}/update?token=%p&ipv4=%i")</td></tr>
                                    </tbody>
                                </table>
                                @if (isDyn)
                                {
                                    <p class="muted-small" style="margin:8px 0 0;"><strong>Dynamic:</strong> set <strong>Hostname</strong> = <span class="mono">&lt;name&gt;.@baseFqdn</span>; <span class="mono">%h</span> sends it as the record to create/update.</p>
                                }
                                <p class="muted-small" style="margin:8px 0 0;"><strong>Server: no <span class="mono">http://</span> / <span class="mono">https://</span></strong> — bare host only, or UniFi's client tries to resolve the scheme as a hostname and never sends. Fill <strong>Password</strong> with the token; <span class="mono">%p</span> mirrors it into the URL and <span class="mono">%i</span> becomes the WAN IPv4 (both are placeholders — UniFi keeps those, drops plain text). Connects over HTTPS.</p>
                                <p class="muted-small" style="margin:6px 0 0;"><strong>IPv4 only:</strong> UniFi has no IPv6 placeholder, so one entry tracks the WAN IPv4. For dual‑stack use the FRITZ!Box section (separate <span class="mono">&lt;ip6addr&gt;</span>).</p>
                                <p class="muted-small" style="margin:6px 0 0;"><strong>Same‑network gotcha:</strong> if the UDM's DDNS host resolves to its own public IP, the request loops back to the UDM (NAT hairpin). Add a local DNS record so <span class="mono">@host</span> resolves to this server's internal IP.</p>
                            </div>
                        </details>
                    </div>
                    <div class="modal-foot">
                        <button type="button" onclick="this.closest('dialog').close()">Close</button>
                    </div>
                </dialog>
            }
        </div>

        <div class="actions">
            <button type="submit">@(isNew ? "Create" : "Save")</button>
            <a class="button ghost" href="/Sources">Cancel</a>
            @if (!isNew)
            {
                @if (kind == SourceKind.Unifi || kind == SourceKind.PublicIp || kind == SourceKind.Dns)
                {
                    <button type="submit" class="ghost" asp-page-handler="Test" name="Id" value="@g!.Id">Test connection</button>
                }
                @if (kind != SourceKind.Push)
                {
                    <button type="submit" class="ghost" asp-page-handler="Refresh" name="Id" value="@g!.Id">Check now</button>
                }
                @if (kind == SourceKind.Push)
                {
                    <button type="submit" class="ghost" asp-page-handler="RegenerateToken" name="Id" value="@g!.Id">Regenerate token</button>
                }
                <button type="submit" class="danger" asp-page-handler="Delete" name="Id" value="@g!.Id" onclick="return confirm('Remove group and all entries?');">Delete group</button>
            }
        </div>
    </form>
</div>

@if (!isNew)
{
    <div class="section-title"><h2>Entries</h2></div>
    <div class="card">
        <table>
            <thead>
                <tr>
                    <th>Label</th>
                    <th>Interface</th>
                    <th>IPv4</th>
                    <th>IPv6</th>
                    <th>Last check</th>
                    <th>Status</th>
                    @if (kind == SourceKind.Unifi) { <th></th> }
                </tr>
            </thead>
            <tbody>
            @foreach (var e in g!.Entries)
            {
                var noIp = string.IsNullOrEmpty(e.CurrentIp) && string.IsNullOrEmpty(e.CurrentIpv6);
                var status = e.LastError == null ? (noIp ? "warn" : "ok") : "err";
                <tr>
                    <td>@e.Label</td>
                    <td class="mono">@(e.InterfaceName ?? "—")</td>
                    <td class="mono">@(e.CurrentIp ?? "—")</td>
                    <td class="mono">@(e.CurrentIpv6 ?? "—")</td>
                    <td><span class="muted-small">@Tz.Format(e.LastChecked)</span></td>
                    <td><span class="status-pill"><span class="status-dot @status"></span>@(e.LastError ?? (noIp ? "pending" : "ok"))</span></td>
                    @if (kind == SourceKind.Unifi)
                    {
                        <td style="text-align:right">
                            <form method="post" asp-page-handler="DeleteEntry" style="display:inline">
                                <input type="hidden" name="Id" value="@g.Id" />
                                <input type="hidden" name="EntryId" value="@e.Id" />
                                <button type="submit" class="danger" onclick="return confirm('Remove entry?');">×</button>
                            </form>
                        </td>
                    }
                </tr>
            }
            </tbody>
        </table>
    </div>
}

@if (isNew)
{
    <script>
        (function () {
            var sel = document.getElementById('kindSelect');
            var fields = document.querySelectorAll('.type-fields');
            var interval = document.getElementById('intervalField');
            function sync() {
                fields.forEach(function (f) {
                    f.classList.toggle('active', f.getAttribute('data-kind') === sel.value);
                });
                if (interval) interval.style.display = (sel.value === 'Push') ? 'none' : '';
            }
            sel.addEventListener('change', sync);
            sync();
        })();
    </script>
}
