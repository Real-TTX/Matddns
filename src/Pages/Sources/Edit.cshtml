@page
@model Matddns.Pages.Sources.EditModel
@{
    var g = Model.Group;
    var isNew = Model.IsNew;
    var kind = g?.Kind ?? SourceKind.PublicIp;
    ViewData["Title"] = (isNew ? "New source" : g!.Name) + " – Matddns";
}

<a class="back-link" href="/Sources">‹ back to Sources</a>

<div class="page-header">
    <div>
        <h1>@(isNew ? "New source group" : g!.Name)</h1>
        <p>@(isNew ? "Pick a type – the matching fields appear automatically." : "Configuration and entries of this source.")</p>
    </div>
</div>

@if (!string.IsNullOrEmpty(Model.Notice)) { <div class="alert ok">@Model.Notice</div> }
@if (!string.IsNullOrEmpty(Model.Error)) { <div class="alert err">@Model.Error</div> }

@if (!string.IsNullOrEmpty(Model.TestResult))
{
    <div class="test-result @(Model.TestOk ? "ok" : "err")">
        <strong>@(Model.TestOk ? "✓ Test succeeded" : "✗ Test failed")</strong>
        <span class="mono">@Model.TestResult</span>
    </div>
}

<div class="card">
    <form method="post" asp-page-handler="@(isNew ? "Create" : "Save")">
        @if (!isNew) { <input type="hidden" name="Id" value="@g!.Id" /> }

        <div class="form-grid">
            <div class="field">
                <label>Name</label>
                <input type="text" name="Name" value="@(g?.Name ?? "")" required placeholder="e.g. Home Unifi" />
            </div>

            <div class="field">
                <label>Type</label>
                @if (isNew)
                {
                    <select name="Kind" id="kindSelect">
                        <option value="PublicIp">Public IP (of the container)</option>
                        <option value="Unifi">Unifi (UDM / UGW)</option>
                        <option value="Static">Static IP (fixed value)</option>
                        <option value="Push">DynDNS receiver (push)</option>
                    </select>
                }
                else
                {
                    var typeLabel = kind switch { SourceKind.Unifi => "Unifi (UDM / UGW)", SourceKind.Static => "Static IP (fixed value)", SourceKind.Push => "DynDNS receiver (push)", _ => "Public IP (of the container)" };
                    <input type="text" value="@typeLabel" disabled />
                    <div class="hint">Type cannot be changed after creation.</div>
                }
            </div>

            @if (isNew || kind != SourceKind.Push)
            {
                <div class="field full" id="intervalField">
                    <label>Interval (seconds)</label>
                    <input type="number" name="IntervalSeconds" value="@(g?.IntervalSeconds ?? 60)" min="15" />
                </div>
            }
        </div>

        <!-- Unifi fields -->
        <div class="type-fields @(kind == SourceKind.Unifi ? "active" : "")" data-kind="Unifi">
            <div class="form-grid" style="margin-top:16px;">
                <div class="field">
                    <label>Base URL</label>
                    <input type="text" name="UniUrl" value="@(g?.Unifi?.BaseUrl ?? "")" placeholder="https://10.10.0.1" />
                    <div class="hint">Without a scheme, https:// is added automatically.</div>
                </div>
                <div class="field">
                    <label>Site</label>
                    <input type="text" name="UniSite" value="@(g?.Unifi?.Site ?? "default")" />
                </div>
                <div class="field">
                    <label>Username</label>
                    <input type="text" name="UniUser" value="@(g?.Unifi?.Username ?? "")" autocomplete="off" />
                    <div class="hint">Local UniFi account (no Ubiquiti cloud login), 2FA off.</div>
                </div>
                <div class="field">
                    <label>Password</label>
                    <input type="password" name="UniPass" placeholder="@(isNew ? "" : "•••••• (leave empty = unchanged)")" autocomplete="new-password" />
                </div>
                <div class="field full">
                    <div class="checkbox-field">
                        <input type="checkbox" id="UniIgnoreCert" name="UniIgnoreCert" value="true" @(g?.Unifi?.IgnoreCertificate != false ? "checked" : "") />
                        <label for="UniIgnoreCert">Ignore self-signed certificate (recommended for UDM)</label>
                    </div>
                </div>
            </div>
        </div>

        <!-- Public IP fields -->
        <div class="type-fields @(kind == SourceKind.PublicIp ? "active" : "")" data-kind="PublicIp">
            <p class="muted" style="margin-top:16px;">No further configuration needed – the container's public IP is detected automatically.</p>
        </div>

        <!-- Static fields -->
        <div class="type-fields @(kind == SourceKind.Static ? "active" : "")" data-kind="Static">
            <div class="form-grid" style="margin-top:16px;">
                <div class="field">
                    <label>Static IPv4</label>
                    <input type="text" name="StaticIp" value="@(g?.Static?.Ip ?? "")" placeholder="203.0.113.10" />
                </div>
                <div class="field">
                    <label>Static IPv6</label>
                    <input type="text" name="StaticIpv6" value="@(g?.Static?.Ipv6 ?? "")" placeholder="2001:db8::1" />
                </div>
                <div class="field full">
                    <div class="hint">Either or both. Rules pick IPv4 for A records and IPv6 for AAAA – e.g. a known server or fallback.</div>
                </div>
            </div>
        </div>

        <!-- Push / DynDNS receiver fields -->
        <div class="type-fields @(kind == SourceKind.Push ? "active" : "")" data-kind="Push">
            @if (isNew)
            {
                <p class="muted" style="margin-top:16px;">A secret token and update URL are generated after creating. Point your router/device/script at it; rules then propagate the pushed IP to your DNS targets.</p>
            }
            else
            {
                var baseUrl = Model.BaseUrl;
                var token = g!.Push?.Token ?? "";
                var host = baseUrl.Replace("https://", "").Replace("http://", "");
                <div class="form-grid" style="margin-top:16px;">
                    <div class="field full">
                        <label>Update URL</label>
                        <input type="text" value="@($"{baseUrl}/api/update?token={token}&ipv4=<your-ipv4>&ipv6=<your-ipv6>")" readonly onclick="this.select()" />
                        <div class="hint">Call this from your device or script. Send <span class="mono">ipv4</span>, <span class="mono">ipv6</span>, or both — the other family stays untouched; omit them to use the caller's IP. Returns JSON, updates on push (no interval). Use a host reachable from your device (not localhost).</div>
                    </div>
                    <div class="field full">
                        <label>Token</label>
                        <input type="text" value="@token" readonly onclick="this.select()" />
                    </div>
                </div>
                <div class="dim-section">
                    <label style="margin-bottom:8px;">Router / device setup (dyndns2)</label>
                    <p class="muted-small" style="margin-top:0; margin-bottom:10px;">For routers/devices that only speak the legacy <strong>dyndns2</strong> protocol. The token is already included in the URLs below — no separate password needed.</p>

                    <details class="collapsible" style="margin-bottom:8px;">
                        <summary>FRITZ!Box</summary>
                        <div style="margin-top:10px;">
                            <label>Update URL</label>
                            <input type="text" value="@($"{baseUrl}/nic/update?token={token}&ipv4=<ipaddr>&ipv6=<ip6addr>")" readonly onclick="this.select()" />
                            <div class="hint">Internet → Permit Access → DynDNS → <em>custom provider</em>. Paste this as the <span class="mono">Update URL</span>; domain name, user name and password can be anything. FRITZ!Box substitutes <span class="mono">&lt;ipaddr&gt;</span> / <span class="mono">&lt;ip6addr&gt;</span> itself.</div>
                        </div>
                    </details>

                    <details class="collapsible">
                        <summary>UniFi (UDM / UGW)</summary>
                        <div style="margin-top:10px;">
                            <label>Server</label>
                            <input type="text" value="@($"{host}/nic/update?token={token}&ipv4=%i")" readonly onclick="this.select()" />
                            <div class="hint">Settings → Internet → Dynamic DNS → <em>Create New</em>. Service = <span class="mono">custom</span>; hostname / username / password = anything; paste the above into the <span class="mono">Server</span> field. UniFi replaces <span class="mono">%i</span> with the WAN IP.</div>
                        </div>
                    </details>
                </div>
            }
        </div>

        <div class="actions">
            <button type="submit">@(isNew ? "Create" : "Save")</button>
            <a class="button ghost" href="/Sources">Cancel</a>
            @if (!isNew)
            {
                @if (kind == SourceKind.Unifi || kind == SourceKind.PublicIp)
                {
                    <button type="submit" class="ghost" asp-page-handler="Test" name="Id" value="@g!.Id">Test connection</button>
                }
                @if (kind != SourceKind.Push)
                {
                    <button type="submit" class="ghost" asp-page-handler="Refresh" name="Id" value="@g!.Id">Check now</button>
                }
                @if (kind == SourceKind.Push)
                {
                    <button type="submit" class="ghost" asp-page-handler="RegenerateToken" name="Id" value="@g!.Id">Regenerate token</button>
                }
                <button type="submit" class="danger" asp-page-handler="Delete" name="Id" value="@g!.Id" onclick="return confirm('Remove group and all entries?');">Delete group</button>
            }
        </div>
    </form>
</div>

@if (!isNew)
{
    <div class="section-title"><h2>Entries</h2></div>
    <div class="card">
        <table>
            <thead>
                <tr>
                    <th>Label</th>
                    <th>Interface</th>
                    <th>IPv4</th>
                    <th>IPv6</th>
                    <th>Last check</th>
                    <th>Status</th>
                    @if (kind == SourceKind.Unifi) { <th></th> }
                </tr>
            </thead>
            <tbody>
            @foreach (var e in g!.Entries)
            {
                var noIp = string.IsNullOrEmpty(e.CurrentIp) && string.IsNullOrEmpty(e.CurrentIpv6);
                var status = e.LastError == null ? (noIp ? "warn" : "ok") : "err";
                <tr>
                    <td>@e.Label</td>
                    <td class="mono">@(e.InterfaceName ?? "—")</td>
                    <td class="mono">@(e.CurrentIp ?? "—")</td>
                    <td class="mono">@(e.CurrentIpv6 ?? "—")</td>
                    <td><span class="muted-small">@Tz.Format(e.LastChecked)</span></td>
                    <td><span class="status-pill"><span class="status-dot @status"></span>@(e.LastError ?? (noIp ? "pending" : "ok"))</span></td>
                    @if (kind == SourceKind.Unifi)
                    {
                        <td style="text-align:right">
                            <form method="post" asp-page-handler="DeleteEntry" style="display:inline">
                                <input type="hidden" name="Id" value="@g.Id" />
                                <input type="hidden" name="EntryId" value="@e.Id" />
                                <button type="submit" class="danger" onclick="return confirm('Remove entry?');">×</button>
                            </form>
                        </td>
                    }
                </tr>
            }
            </tbody>
        </table>

        @if (kind == SourceKind.Unifi)
        {
            <div class="muted-small" style="margin-top:12px;">Entries are discovered automatically from the UDM – one per WAN. No manual entries.</div>
        }
    </div>
}

@if (isNew)
{
    <script>
        (function () {
            var sel = document.getElementById('kindSelect');
            var fields = document.querySelectorAll('.type-fields');
            var interval = document.getElementById('intervalField');
            function sync() {
                fields.forEach(function (f) {
                    f.classList.toggle('active', f.getAttribute('data-kind') === sel.value);
                });
                if (interval) interval.style.display = (sel.value === 'Push') ? 'none' : '';
            }
            sel.addEventListener('change', sync);
            sync();
        })();
    </script>
}
