@page
@model Matddns.Pages.Domains.IndexModel
@{
    ViewData["Title"] = "Domains – Matddns";
}

<div class="page-header">
    <div><h1>Domains</h1></div>
    <a class="button" href="/Domains/Edit">+ New domain group</a>
</div>

@if (!string.IsNullOrEmpty(Model.Notice)) { <div class="alert ok">@Model.Notice</div> }
@if (!string.IsNullOrEmpty(Model.Error)) { <div class="alert err">@Model.Error</div> }

@if (Model.Groups.Count == 0)
{
    <div class="empty-state">
        No domain groups yet.<br />
        <a class="button" style="margin-top:12px;" href="/Domains/Edit">Create the first group</a>
    </div>
}
else
{
    <div data-dt>
        <div class="table-toolbar">
            <div class="dt-search">
                <span class="ico">⌕</span>
                <input type="text" data-dt-search placeholder="Search domains, records…" autocomplete="off" />
            </div>
            <select data-dt-filter="kind" aria-label="Filter by provider">
                <option value="">All providers</option>
                <option value="dyndns">DynDNS</option>
                <option value="netcup">Netcup</option>
            </select>
            <span class="dt-count" data-dt-count></span>
        </div>
        <div class="dtable-wrap">
            <table class="dtable">
                <thead>
                    <tr><th>Name</th><th class="hide-sm">Provider</th><th>Record</th><th>Type</th><th></th></tr>
                </thead>
                @foreach (var g in Model.Groups)
                {
                    var kindKey = g.Kind == DomainKind.Netcup ? "netcup" : "dyndns";
                    var kindLabel = g.Kind == DomainKind.Netcup ? "Netcup API" : "DynDNS";
                    var entries = g.Entries.ToList();
                    var search = $"{g.Name} {kindLabel} {string.Join(' ', entries.Select(e => $"{e.Hostname} {e.Type}"))}";
                    <tbody class="dt-group" data-search="@search" data-kind="@kindKey" data-href="/Domains/Edit?id=@g.Id">
                        <tr class="dt-parent @(entries.Count > 0 ? "has-children" : "")">
                            <td class="dt-name">@g.Name</td>
                            <td class="hide-sm"><span class="badge @(g.Kind == DomainKind.Netcup ? "update" : "info")">@kindLabel</span></td>
                            <td class="cell-muted">@entries.Count record@(entries.Count == 1 ? "" : "s")</td>
                            <td></td>
                            <td class="dt-go">›</td>
                        </tr>
                        @for (int i = 0; i < entries.Count; i++)
                        {
                            var e = entries[i];
                            <tr class="dt-child @(i == entries.Count - 1 ? "last" : "")">
                                <td></td>
                                <td class="hide-sm"></td>
                                <td class="mono"><span class="dt-sub">@e.Hostname</span></td>
                                <td><span class="badge muted">@e.Type</span></td>
                                <td></td>
                            </tr>
                        }
                    </tbody>
                }
                <tbody class="dt-empty" hidden><tr><td colspan="5">No domains match your search.</td></tr></tbody>
            </table>
        </div>
    </div>
}
