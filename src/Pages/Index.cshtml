@page
@model IndexModel
@{
    ViewData["Title"] = "Dashboard – Matddns";
    var s = Model.Snapshot;
}

<div class="page-header">
    <div>
        <h1>Dashboard</h1>
        <p class="muted-small">All times in @Tz.Label().</p>
    </div>
    <form method="get"><button type="submit" class="ghost">Refresh</button></form>
</div>

<div class="stat-grid">
    <div class="stat-card">
        <span class="stat-dot @(s.Sources.Errors == 0 ? "ok" : "err")" title="@(s.Sources.Errors) source error(s)"></span>
        <div class="stat-num">@s.Sources.Ok<span class="stat-den">/@s.Sources.Entries</span></div>
        <div class="stat-label">Source IPs OK</div>
    </div>
    <div class="stat-card">
        <span class="stat-dot @(s.Rules.Issues == 0 ? "ok" : "err")" title="@(s.Rules.Issues) rule issue(s)"></span>
        <div class="stat-num">@s.Rules.Ok<span class="stat-den">/@s.Rules.Total</span></div>
        <div class="stat-label">Rules OK</div>
    </div>
    <div class="stat-card">
        <div class="stat-num">@s.IpChanges.Last24h</div>
        <div class="stat-label">IP changes (24h)</div>
    </div>
    <div class="stat-card">
        <span class="stat-dot @(s.ErrorsLast24h == 0 ? "ok" : "err")" title="@s.ErrorsLast24h error(s) in 24h"></span>
        <div class="stat-num">@s.ErrorsLast24h</div>
        <div class="stat-label">Errors (24h)</div>
    </div>
</div>

<div class="section-title"><h2>Sources</h2><a class="muted-small" href="/Sources">manage →</a></div>
<div class="card">
    <table>
        <thead><tr><th class="hide-sm">Source</th><th>Entry</th><th>IPv4</th><th class="hide-sm">IPv6</th><th class="hide-sm">Last check</th><th>Status</th></tr></thead>
        <tbody>
        @foreach (var src in s.SourceList)
        {
            @foreach (var e in src.Entries)
            {
                var noIp = string.IsNullOrEmpty(e.Ip) && string.IsNullOrEmpty(e.Ipv6);
                var st = e.Error != null ? "err" : (noIp ? "warn" : "ok");
                <tr>
                    <td class="hide-sm">@src.Name <span class="muted-small">(@(src.Kind == "Push" ? "DynDNS Server" : src.Kind == "Dns" ? "DNS lookup" : src.Kind))</span></td>
                    <td>@e.Label</td>
                    <td class="mono">@(e.Ip ?? "—")</td>
                    <td class="mono hide-sm">@(e.Ipv6 ?? "—")</td>
                    <td class="hide-sm"><span class="muted-small">@Tz.Format(e.LastChecked)</span></td>
                    <td><span class="status-pill"><span class="status-dot @st"></span><span class="hide-sm">@(e.Error ?? (noIp ? "pending" : "ok"))</span></span></td>
                </tr>
            }
        }
        @if (s.SourceList.Count == 0)
        {
            <tr><td colspan="6" class="muted">No sources configured. <a href="/Sources/Edit">Add one</a>.</td></tr>
        }
        </tbody>
    </table>
</div>

<div class="section-title"><h2>Rules</h2><a class="muted-small" href="/Rules">manage →</a></div>
<div class="card">
    <table>
        <thead><tr><th>Target</th><th class="hide-sm">Group</th><th>Last set</th><th class="hide-sm">When</th><th>Status</th></tr></thead>
        <tbody>
        @foreach (var r in s.RuleList)
        {
            var st = !r.Enabled ? "muted" : (r.Issue ? "err" : (r.Ok ? "ok" : "warn"));
            <tr>
                <td><span class="badge info">@r.Type</span> <span class="mono">@r.Target</span></td>
                <td class="muted-small hide-sm">@(r.Group ?? "—")</td>
                <td class="mono">@(r.LastValue ?? "—")</td>
                <td class="hide-sm"><span class="muted-small">@Tz.Format(r.LastChange, "yyyy-MM-dd HH:mm")</span></td>
                <td><span class="status-pill"><span class="status-dot @st"></span><span class="hide-sm">@(!r.Enabled ? "disabled" : (r.Issue ? "issue" : (r.Ok ? "ok" : "pending")))</span></span></td>
            </tr>
        }
        @if (s.RuleList.Count == 0)
        {
            <tr><td colspan="5" class="muted">No rules configured. <a href="/Rules/Edit">Add one</a>.</td></tr>
        }
        </tbody>
    </table>
</div>

<div class="section-title"><h2>Recent IP changes</h2><a class="muted-small" href="/Log?Level=Update">full log →</a></div>
<div class="card">
    <table>
        <thead><tr><th>Time</th><th>Target</th><th class="hide-sm">Detail</th></tr></thead>
        <tbody>
        @foreach (var c in s.IpChanges.Recent)
        {
            <tr>
                <td class="mono">@Tz.Format(c.Time)</td>
                <td class="mono">@c.Target</td>
                <td class="muted-small hide-sm">@c.Detail</td>
            </tr>
        }
        @if (s.IpChanges.Recent.Count == 0)
        {
            <tr><td colspan="3" class="muted">No IP changes recorded yet.</td></tr>
        }
        </tbody>
    </table>
</div>
